# ============ 方案 A：Anthropic Claude（品質最好，需付費金鑰） ============
# 到 https://console.anthropic.com 申請
ANTHROPIC_API_KEY=sk-ant-...
# 模型（選填，預設 claude-opus-4-8；想省錢可改 claude-sonnet-5）
#MODEL=claude-opus-4-8

# ============ 方案 B：免 Anthropic 金鑰（擇一，設定 OPENAI_BASE_URL 後自動生效） ============

# --- B1. Ollama 本地模型（完全免費，需先安裝 https://ollama.com 並 ollama pull 模型） ---
#OPENAI_BASE_URL=http://localhost:11434/v1
#MODEL=qwen3:8b

# --- B2. Google AI Studio（有免費額度，https://aistudio.google.com 取得金鑰） ---
#OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
#OPENAI_API_KEY=你的_Google_AI_Studio_金鑰
#MODEL=gemini-2.5-flash

# --- B3. OpenRouter 免費模型（https://openrouter.ai 註冊取得金鑰，選帶 :free 的模型） ---
#OPENAI_BASE_URL=https://openrouter.ai/api/v1
#OPENAI_API_KEY=sk-or-...
#MODEL=deepseek/deepseek-chat-v3-0324:free

# --- B4. Groq（有免費額度，https://console.groq.com） ---
#OPENAI_BASE_URL=https://api.groq.com/openai/v1
#OPENAI_API_KEY=gsk_...
#MODEL=llama-3.3-70b-versatile

# ============ 其他 ============
# 伺服器埠號（選填，預設 3000）
#PORT=3000
